# ── AI (серверна частина) ─────────────────────────────────────
# Ключ читається ТІЛЬКИ на сервері (route handler /api/ai).
# У браузер не потрапляє. На Vercel додай у Project Settings → Environment Variables.
ANTHROPIC_API_KEY=sk-ant-...

# ── База даних (Prisma) ───────────────────────────────────────
# PostgreSQL connection string. Локально, напр.:
# postgresql://user:password@localhost:5432/aiwok?schema=public
DATABASE_URL=

# ── Auth.js (NextAuth) ────────────────────────────────────────
# Вхід — Credentials provider (email + password). Інших змінних не треба.
# ОБОВ'ЯЗКОВО для JWT-сесій. Згенерувати: `openssl rand -base64 32`
# На Vercel додай у Project Settings → Environment Variables.
AUTH_SECRET=
